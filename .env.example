# Copy this file to .env and fill with your own values
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-preview

# DashScope (Qwen Voice-Enrollment + Qwen3-TTS-VC)
DASHSCOPE_API_KEY=
QWEN_TTS_MODEL=qwen3-tts-vc-2026-01-22
QWEN_VOICE_ENROLLMENT_MODEL=qwen-voice-enrollment
DASHSCOPE_TTS_CUSTOMIZATION_URL=https://dashscope-intl.aliyuncs.com/api/v1/services/audio/tts/customization
DASHSCOPE_BASE_HTTP_API_URL=
DEFAULT_VOICE_FILE=
TTS_CHAR_LIMIT=300
VOICE_CACHE_TTL_SEC=1209600
TTS_CROSSFADE_MS=130

PEXELS_API_KEY=
PIXABAY_API_KEY=
MAPBOX_TOKEN=
CESIUM_ION_TOKEN=
GOOGLE_MAPS_API_KEY=

# Optional paths/config overrides
YTDLP_PATH=yt-dlp
YOUTUBE_COOKIES_PATH=
GEO_MUSIC_DIR=
GEO_FONTS_DIR=
CAPTION_FONT_NAME=Montserrat Bold
FFMPEG_BIN=ffmpeg
